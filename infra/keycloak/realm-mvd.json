{
  "realm": "mvd",
  "enabled": true,
  "sslRequired": "none",
  "displayName": "MVD Realm",
  "accessTokenLifespan": 600,
  "roles": {
    "realm": [
      {"name": "admin", "description": "Administrator with full access"},
      {"name": "provisioner", "description": "Can create and delete tenants"},
      {"name": "participant", "description": "Regular participant context access"}
    ]
  },
  "clientScopes": [
    {"name": "identity-api:read",      "protocol": "openid-connect", "attributes": {"include.in.token.scope": "true", "display.on.consent.screen": "true"}},
    {"name": "identity-api:write",     "protocol": "openid-connect", "attributes": {"include.in.token.scope": "true", "display.on.consent.screen": "true"}},
    {"name": "issuer-admin-api:read",  "protocol": "openid-connect", "attributes": {"include.in.token.scope": "true", "display.on.consent.screen": "true"}},
    {"name": "issuer-admin-api:write", "protocol": "openid-connect", "attributes": {"include.in.token.scope": "true", "display.on.consent.screen": "true"}}
  ],
  "defaultOptionalClientScopes": [
    "offline_access",
    "identity-api:read", "identity-api:write",
    "issuer-admin-api:read", "issuer-admin-api:write"
  ],
  "clients": [
    {
      "clientId": "admin",
      "name": "MVD Admin",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "secret": "edc-v-admin-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "fullScopeAllowed": true,
      "protocolMappers": [
        {"name": "role", "protocol": "openid-connect", "protocolMapper": "oidc-hardcoded-claim-mapper",
         "config": {"claim.name": "role", "claim.value": "admin", "jsonType.label": "String",
                    "access.token.claim": "true", "id.token.claim": "true", "userinfo.token.claim": "true"}}
      ],
      "defaultClientScopes": ["issuer-admin-api:write", "issuer-admin-api:read", "identity-api:write", "identity-api:read"]
    },
    {
      "clientId": "provisioner",
      "name": "Provisioner",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "secret": "provisioner-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "fullScopeAllowed": true,
      "protocolMappers": [
        {"name": "role", "protocol": "openid-connect", "protocolMapper": "oidc-hardcoded-claim-mapper",
         "config": {"claim.name": "role", "claim.value": "provisioner", "jsonType.label": "String",
                    "access.token.claim": "true", "id.token.claim": "true", "userinfo.token.claim": "true"}}
      ],
      "defaultClientScopes": ["issuer-admin-api:write", "issuer-admin-api:read", "identity-api:write", "identity-api:read"]
    },
    {
      "clientId": "issuer",
      "name": "Issuer Tenant Client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "secret": "issuer-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "fullScopeAllowed": true,
      "protocolMappers": [
        {"name": "role", "protocol": "openid-connect", "protocolMapper": "oidc-hardcoded-claim-mapper",
         "config": {"claim.name": "role", "claim.value": "participant", "jsonType.label": "String",
                    "access.token.claim": "true", "id.token.claim": "true", "userinfo.token.claim": "true"}},
        {"name": "participantContextId", "protocol": "openid-connect", "protocolMapper": "oidc-hardcoded-claim-mapper",
         "config": {"claim.name": "participant_context_id", "claim.value": "issuer", "jsonType.label": "String",
                    "access.token.claim": "true", "id.token.claim": "true", "userinfo.token.claim": "true"}}
      ],
      "defaultClientScopes": ["issuer-admin-api:write", "issuer-admin-api:read", "identity-api:write", "identity-api:read"]
    },
    {
      "clientId": "participant-a",
      "name": "Participant A Vault-Access Client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "secret": "participant-a-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "fullScopeAllowed": true,
      "protocolMappers": [
        {"name": "role", "protocol": "openid-connect", "protocolMapper": "oidc-hardcoded-claim-mapper",
         "config": {"claim.name": "role", "claim.value": "participant", "jsonType.label": "String",
                    "access.token.claim": "true", "id.token.claim": "true", "userinfo.token.claim": "true"}},
        {"name": "participantContextId", "protocol": "openid-connect", "protocolMapper": "oidc-hardcoded-claim-mapper",
         "config": {"claim.name": "participant_context_id", "claim.value": "participant-a", "jsonType.label": "String",
                    "access.token.claim": "true", "id.token.claim": "true", "userinfo.token.claim": "true"}}
      ]
    },
    {
      "clientId": "participant-b",
      "name": "Participant B Vault-Access Client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "secret": "participant-b-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "fullScopeAllowed": true,
      "protocolMappers": [
        {"name": "role", "protocol": "openid-connect", "protocolMapper": "oidc-hardcoded-claim-mapper",
         "config": {"claim.name": "role", "claim.value": "participant", "jsonType.label": "String",
                    "access.token.claim": "true", "id.token.claim": "true", "userinfo.token.claim": "true"}},
        {"name": "participantContextId", "protocol": "openid-connect", "protocolMapper": "oidc-hardcoded-claim-mapper",
         "config": {"claim.name": "participant_context_id", "claim.value": "participant-b", "jsonType.label": "String",
                    "access.token.claim": "true", "id.token.claim": "true", "userinfo.token.claim": "true"}}
      ]
    }
  ],
  "users": []
}
